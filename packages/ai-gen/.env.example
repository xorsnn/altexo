# Copy to .env in this package root (gitignored), then fill in.
# Values already in your shell environment override this file.

# Google Gemini — used for Nano Banana Pro (image) and Veo 3.1 (video).
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Kling official API (api.klingai.com) — used for Kling 3 video.
# Auth is a JWT signed with access key + secret. Get both from
# https://app.klingai.com/global/dev/account
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# OpenAI — used for gpt-image-1 (image), via `gen-openai.js`.
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Optional overrides (defaults work out of the box; leave unset to keep them) ---

# Path to a JSON file that overrides entries from models.default.json
# (per-model shallow replace: a model present here replaces the default entry
# wholesale; others keep defaults; new aliases are added). Absolute, or
# relative to the process cwd.
# AI_GEN_MODELS_CONFIG=

# Override the output root. Default: ./out (package-local). Absolute, or
# relative to the process cwd.
# AI_GEN_OUT_ROOT=

# Override the Kling API base URL. Default: https://api.klingai.com (still resolves).
# The international host moved to https://api-singapore.klingai.com — use whatever the
# Kling dev console shows for your account; some newer endpoints may require it.
# KLING_BASE_URL=
